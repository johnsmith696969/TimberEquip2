rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public listing images (readable by everyone, writable by owners/admins)
    match /listings/{listingId}/images/{filePath=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && (isDraftUploader() || isOwner(request.auth.uid, listingId) || isAdmin(request.auth.uid))
        && validateImage(request.resource);
      allow delete: if request.auth != null 
        && (isUploader(resource) || isOwner(request.auth.uid, listingId) || isAdmin(request.auth.uid));
    }

    // Listing videos (readable by everyone, writable by owners/admins)
    match /listings/{listingId}/videos/{filePath=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && (isDraftUploader() || isOwner(request.auth.uid, listingId) || isAdmin(request.auth.uid))
        && validateVideo(request.resource);
      allow delete: if request.auth != null 
        && (isUploader(resource) || isOwner(request.auth.uid, listingId) || isAdmin(request.auth.uid));
    }

    // Brand assets (logos, favicons) - readable by all, writable by admins only
    match /brand-assets/{assetType}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // User avatars (readable by all, writable by owner/admins)
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
        && (request.auth.uid == userId || isAdmin(request.auth.uid))
        && validateImage(request.resource);
      allow delete: if request.auth != null 
        && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    // User profile photos
    match /users/{userId}/photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
        && (request.auth.uid == userId || isAdmin(request.auth.uid))
        && validateImage(request.resource);
      allow delete: if request.auth != null 
        && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    // Private files (invoices, documents) - accessible only by owner/admins
    match /private/{userId}/documents/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid))
        && validateDocument(request.resource);
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    // Auction tax-exempt certificates - readable by the bidder and admins, writable by the bidder.
    match /tax-certificates/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.metadata.uploadedBy == userId
        && validateDocument(request.resource);
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    // Bulk import media (images/videos uploaded by sellers and admins for batch listing creation)
    match /bulk-imports/{userId}/{batchPath=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
      allow write: if request.auth != null
        && (request.auth.uid == userId || isAdmin(request.auth.uid))
        && request.resource.size < 500 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
    }

    // Dealer feed assets (imported media from external feeds)
    match /dealer-feeds/{dealerId}/{feedPath=**} {
      allow read: if request.auth != null && (request.auth.uid == dealerId || isAdmin(request.auth.uid));
      allow write: if request.auth != null
        && (request.auth.uid == dealerId || isAdmin(request.auth.uid))
        && request.resource.size < 500 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null && (request.auth.uid == dealerId || isAdmin(request.auth.uid));
    }

    // Temporary uploads (auto-delete files)
    match /temp/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('application/pdf') || request.resource.contentType.matches('text/.*'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny all
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }

    // Helper functions
    function isAdmin(uid) {
      // Relies on Firebase custom claims only. The Firestore user doc lives in a named
      // database (not default), so cross-service reads from Storage rules would hit the
      // wrong DB. Custom claims are set when a role is assigned and are authoritative.
      return request.auth.token.role in ['super_admin', 'admin', 'developer']
        && request.auth.token.email_verified == true;
    }

    function isOwner(uid, listingId) {
      // Listings live in a named Firestore database which Storage rules cannot
      // cross-service read. Ownership is enforced by:
      // 1. isDraftUploader() — upload metadata.uploadedBy must match auth UID
      // 2. isAdmin() — admin custom claim bypass
      // 3. Server-side upload endpoints validate ownership before accepting files
      // The Firestore cross-service read is intentionally removed to prevent
      // false negatives and to avoid the isDraftUploader bypass risk.
      return false;
    }

    function isDraftUploader() {
      return request.resource.metadata.uploadedBy == request.auth.uid;
    }

    function isUploader(resource) {
      return resource.metadata.uploadedBy == request.auth.uid;
    }

    function validateImage(resource) {
      // Max 10MB for images
      return resource.size < 10 * 1024 * 1024 
        && resource.contentType.matches('image/.*');
    }

    function validateVideo(resource) {
      // Max 500MB for videos
      return resource.size < 500 * 1024 * 1024 
        && resource.contentType.matches('video/.*');
    }

    function validateDocument(resource) {
      return resource.size < 25 * 1024 * 1024 &&
        (
          resource.contentType.matches('application/pdf') ||
          resource.contentType.matches('application/msword') ||
          resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document') ||
          resource.contentType.matches('text/plain') ||
          resource.contentType.matches('image/.*')
        );
    }

  }
}
