{
  "name": "forestry-equipment-sales",
  "private": true,
  "version": "1.0.0",
  "description": "Forestry Equipment Sales - Enterprise logging equipment marketplace",
  "author": "Forestry Equipment Sales",
  "homepage": "https://www.timberequip.com",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:noindex": "node scripts/run-seo-command.mjs noindex vite build",
    "build:indexable": "node scripts/run-seo-command.mjs indexable vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "validate:deploy": "node scripts/validate-deploy-config.mjs",
    "validate:preview": "node scripts/validate-deploy-config.mjs --env preview",
    "validate:staging": "node scripts/validate-deploy-config.mjs --env staging",
    "validate:staging:smoke": "node scripts/validate-deploy-config.mjs --env staging --require-smoke",
    "validate:production": "node scripts/validate-deploy-config.mjs --env production",
    "validate:production:smoke": "node scripts/validate-deploy-config.mjs --env production --require-smoke",
    "verify:staging": "npm run lint && npm test && npm run build:noindex",
    "verify:production": "npm run lint && npm test && npm run build:indexable",
    "governance:backfill": "node scripts/backfill-listing-governance.cjs",
    "images:backfill:avif": "node scripts/backfill-listing-avif-source-images.cjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "smoke:routes": "node scripts/http-smoke-check.mjs",
    "qa:dealer-feeds": "node scripts/test-dealer-feeds.mjs",
    "ops:alerts:render": "node scripts/render-alert-policies.mjs",
    "ops:alerts:apply": "node scripts/apply-alert-policies.mjs",
    "ops:staging:setup": "node scripts/setup-staging-project.mjs",
    "ops:firestore:backup": "node scripts/firestore-backup.mjs export",
    "ops:firestore:backup:apply-retention": "node scripts/firestore-backup.mjs apply-retention",
    "sendgrid:templates:sync": "node scripts/sync-sendgrid-templates.mjs",
    "prepare:seo-mode": "node scripts/prepare-seo-mode.mjs",
    "deploy:firebase": "node scripts/firebase-deploy.mjs",
    "deploy:preview": "node scripts/firebase-deploy.mjs --env preview",
    "deploy:staging": "node scripts/firebase-deploy.mjs --env staging",
    "deploy:staging:ci": "node scripts/firebase-deploy.mjs --env staging --ci",
    "deploy:production": "node scripts/firebase-deploy.mjs --env production",
    "deploy:production:ci": "node scripts/firebase-deploy.mjs --env production --ci",
    "deploy:noindex": "node scripts/run-seo-command.mjs noindex \"npm run build && npx firebase-tools deploy --only hosting\"",
    "deploy:indexable": "node scripts/run-seo-command.mjs indexable \"npm run build && npx firebase-tools deploy --only hosting\"",
    "hosting:serve": "npx firebase-tools emulators:start --only hosting",
    "test": "vitest run",
    "test:e2e:public": "playwright test tests-e2e/public-critical-journeys.spec.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dataconnect/generated-timberequip-auctions": "file:src/lib/dataconnect/generated/auctions",
    "@dataconnect/generated-timberequip-billing": "file:src/lib/dataconnect/generated/billing",
    "@dataconnect/generated-timberequip-dealers": "file:src/lib/dataconnect/generated/dealers",
    "@dataconnect/generated-timberequip-leads": "file:src/lib/dataconnect/generated/leads",
    "@dataconnect/generated-timberequip-listing-governance": "file:src/lib/dataconnect/generated/listing-governance",
    "@dataconnect/generated-timberequip-marketplace": "file:src/lib/dataconnect/generated/marketplace",
    "@google-cloud/vision": "^4.3.2",
    "@sentry/node": "10.46.0",
    "@sentry/react": "10.46.0",
    "@tailwindcss/vite": "4.1.14",
    "@types/leaflet": "1.9.21",
    "@types/multer": "2.1.0",
    "@vitejs/plugin-react": "5.0.4",
    "clsx": "2.1.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "date-fns": "4.1.0",
    "dotenv": "17.2.3",
    "exceljs": "4.4.0",
    "express": "4.21.2",
    "express-rate-limit": "8.3.1",
    "firebase": "12.11.0",
    "firebase-admin": "13.7.0",
    "framer-motion": "12.38.0",
    "helmet": "8.1.0",
    "helmet-csp": "4.0.0",
    "leaflet": "1.9.4",
    "lucide-react": "0.546.0",
    "lusca": "1.7.0",
    "multer": "2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-firebase-hooks": "5.1.1",
    "react-router-dom": "7.13.1",
    "react-window": "2.2.7",
    "react-zoom-pan-pinch": "3.7.0",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "stripe": "20.4.1",
    "tailwind-merge": "3.5.0",
    "vite": "6.2.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/lusca": "^1.7.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/stripe": "^8.0.416",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
