          : LIGHT_LOGO_SRC;
        lightSrc = sanitizeLogoSrc(lightSrc, LIGHT_LOGO_SRC);
      }

      img.setAttribute('data-fes-logo-light-src', lightSrc);
      img.setAttribute('data-fes-logo-dusk-src', duskSrc);

      var desiredSrc = desiredTheme === MODE_DUSK ? duskSrc : lightSrc;
      if (!desiredSrc) return;

      img.removeAttribute('data-fes-logo-ready');

      var settle = function() {
        markLogoReady(img, desiredSrc, desiredTheme);
      };

      if (normalizeUrl(currentSrc) !== normalizeUrl(desiredSrc)) {
        img.setAttribute('src', desiredSrc);
      }

      if (img.hasAttribute('srcset')) {
        img.setAttribute('srcset', desiredSrc);
      }

      ['data-src', 'data-original', 'data-lazy-src', 'data-srcset'].forEach(function(attr){
