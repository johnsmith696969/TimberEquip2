  var theme = resolveTheme(mode);

  root.setAttribute('data-theme-mode', mode);
  root.setAttribute('data-theme', theme);
  root.classList.remove(theme === MODE_DUSK ? 'theme-light' : 'theme-dusk');
  root.classList.add(theme === MODE_DUSK ? 'theme-dusk' : 'theme-light');

