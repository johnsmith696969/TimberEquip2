    img.setAttribute('data-fes-logo-theme', theme);
  }

  function syncBrandLogos(theme) {
    if (!document.querySelectorAll) return;

    var desiredTheme = theme === MODE_DUSK ? MODE_DUSK : MODE_LIGHT;
    var desiredFallbackSrc = desiredTheme === MODE_DUSK ? DUSK_LOGO_SRC : LIGHT_LOGO_SRC;
    warmLogo(desiredFallbackSrc);

    document.querySelectorAll(LOGO_SELECTOR).forEach(function(img){
      if (!img || !img.getAttribute) return;

      var currentSrc = sanitizeLogoSrc(img.getAttribute('src') || '', '');
      var lightSrc = sanitizeLogoSrc(img.getAttribute('data-fes-logo-light-src'), '');
      var duskSrc = sanitizeLogoSrc(img.getAttribute('data-fes-logo-dusk-src'), DUSK_LOGO_SRC) || DUSK_LOGO_SRC;

      if (!lightSrc || srcMatchesLogoMarker(lightSrc, KNOWN_DUSK_LOGO_MARKERS)) {
        lightSrc = currentSrc && !srcMatchesLogoMarker(currentSrc, KNOWN_DUSK_LOGO_MARKERS)
