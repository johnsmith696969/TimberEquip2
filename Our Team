  document.addEventListener('DOMContentLoaded', function () {
    syncBrandLogos(resolveTheme(readSavedMode()));
  }, { once: true });
  window.addEventListener('load', function () {
    syncBrandLogos(resolveTheme(readSavedMode()));
  }, { once: true });
