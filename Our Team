<script>
(function () {
  var STORAGE_KEY = 'fes-theme-mode';
  var MODE_SYSTEM = 'system';
  var MODE_LIGHT = 'light';
  var MODE_DUSK = 'dusk';
  var LIGHT_LOGO_SRC = 'https://forestry-equipment-sales.directoryup.comhttps://ik.imagekit.io/aqa9zbltl/images/Superior-Equipment-Sales-Logo-Transparent-3.png';
  var DUSK_LOGO_SRC = 'https://forestry-equipment-sales.directoryup.com/images/Superior-Equipment-Sales-Logo-Transparent-Dusk-1.png';
  var KNOWN_DUSK_LOGO_MARKERS = ['Superior-Equipment-Sales-Logo-Transparent-Dusk-1.png', 'Superior-Equipment-Sales-Logo-Dusk.png', 'SES_Logo_Dusk-Mode-removebg.png', 'Forestry-Equipment-Superstore-Dusk-Mode-Logo.png'];
  // Unified logo swap controller for both light and dusk themes.
  var LOGO_SELECTOR = '#website_logo img, .header-left-container .logo img, .header .logo img, .header-main-row .logo img, .mobile_website_logo img, .mobile_website_logo .visible-xs img, .mobile-main-menu .logo img, .navbar-brand img, #footer .footer-logo img, #footer .navbar-brand.footer-logo img';
  var root = document.documentElement;
  var themeColorMeta = document.querySelector('meta[name="theme-color"]');
  var logoObserver = null;

  function normalizeMode(mode) {
    mode = String(mode || MODE_SYSTEM).toLowerCase();
    if (mode !== MODE_LIGHT && mode !== MODE_DUSK && mode !== MODE_SYSTEM) {
      mode = MODE_SYSTEM;
    }
    return mode;
  }

  function readSavedMode() {
    try {
      return normalizeMode(window.localStorage.getItem(STORAGE_KEY) || MODE_SYSTEM);
    } catch (err) {
      return MODE_SYSTEM;
    }
  }

  function resolveTheme(mode) {
    mode = normalizeMode(mode);
    if (mode === MODE_DUSK) return MODE_DUSK;
    if (mode === MODE_LIGHT) return MODE_LIGHT;
    return !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)
      ? MODE_DUSK
      : MODE_LIGHT;
  }

  function normalizeUrl(url) {
    try {
      return new URL(url, window.location.href).href;
    } catch (err) {
      return String(url || '');
    }
  }

  function srcMatchesLogoMarker(src, markers) {
    src = String(src || '');
    if (!src || !markers || !markers.length) {
      return false;
    }

    return markers.some(function(marker) {
      return src.indexOf(marker) >= 0;
    });
  }

  function sanitizeLogoSrc(src, fallback) {
    src = String(src || '').trim();
    if (!src) return fallback || '';

    // Repair malformed protocol strings like: https//cdn.com/logo.png
    if (src.indexOf('https//') === 0) {
      src = 'https://' + src.slice('https//'.length);
    } else if (src.indexOf('http//') === 0) {
      src = 'http://' + src.slice('http//'.length);
    } else if (src.indexOf('//') === 0) {
      src = window.location.protocol + src;
    }

    // Repair malformed concatenations like: https://site.comhttps://cdn.com/logo.png
    var lowerSrc = src.toLowerCase();
    var startsHttps = lowerSrc.indexOf('https://') === 0;
    var startsHttp = lowerSrc.indexOf('http://') === 0;
    var nextHttps = lowerSrc.indexOf('https://', startsHttps ? 8 : (startsHttp ? 7 : 0));
    var nextHttp = lowerSrc.indexOf('http://', startsHttps ? 8 : (startsHttp ? 7 : 0));
    var cut = Math.max(nextHttps, nextHttp);

    if ((startsHttps || startsHttp) && cut > 0) {
      src = src.slice(cut);
    }

    return src || (fallback || '');
  }

  function warmLogo(src) {
    if (!src || !document.head) return;
    var href = normalizeUrl(src);
    if (document.querySelector('link[rel="preload"][as="image"][href="' + href + '"]')) {
      return;
    }
    var preload = document.createElement('link');
    preload.rel = 'preload';
    preload.as = 'image';
    preload.href = href;
    document.head.appendChild(preload);
