  try {
    mode = String(window.localStorage.getItem(STORAGE_KEY) || 'system').toLowerCase();
  } catch (error) {
    mode = 'system';
  }

  if (mode !== 'system' && mode !== 'light' && mode !== 'dusk') {
    mode = 'system';
  }

  var mq = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;
  var theme = mode === 'dusk'
    ? 'dusk'
    : mode === 'light'
      ? 'light'
      : (mq && mq.matches ? 'dusk' : 'light');

  root.setAttribute('data-theme-mode', mode);
  root.setAttribute('data-theme', theme);
  root.classList.toggle('theme-dusk', theme === 'dusk');
  root.classList.toggle('theme-light', theme !== 'dusk');
})();
